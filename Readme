- !!! MAIN PYTHON CODE !!! -
 HOW IS THE CODE DISTRIBUTED ?

main.py
camera.py
printer.py
ui.py
config.py

- CODE -

from time import sleep
from pathlib import Path
import RPi.GPIO as GPIO
from camera import capture_photo
from printer import print_photo
from ui import show_screen, show_idle, show_message

BUTTON_PIN = 18
PHOTO_PATH = Path("output/photo.jpg")

GPIO.setmode(GPIO.BCM)
GPIO.setup(BUTTON_PIN, GPIO.IN, pull_up_down=GPIO.PUD_UP)

def on_button(channel):
    sleep(0.05)
    if GPIO.input(channel) == GPIO.LOW:
        return

    try:
        show_message("Tomando foto...")
        capture_photo(str(PHOTO_PATH))
        show_screen(str(PHOTO_PATH))
        show_message("Imprimiendo...")
        print_photo(str(PHOTO_PATH))
        show_message("Listo")
        sleep(1)
        show_idle()
    except Exception as e:
        show_message(f"Error: {e}")
        sleep(2)
        show_idle()

GPIO.add_event_detect(BUTTON_PIN, GPIO.FALLING, callback=on_button, bouncetime=250)

show_idle()

try:
    while True:
        sleep(1)
except KeyboardInterrupt:
    GPIO.cleanup()


